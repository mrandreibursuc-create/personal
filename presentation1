let lang="fr";
function applyLang(){
  document.querySelectorAll("[data-t]").forEach(el=>{
    const k=el.getAttribute("data-t");
    if(I18N[k]) el.innerHTML=I18N[k][lang];
  });
  document.documentElement.lang=lang;
}
function setLang(l){
  lang=l;
  document.getElementById("fr").classList.toggle("on",l==="fr");
  document.getElementById("en").classList.toggle("on",l==="en");
  applyLang();
}

/* ---------------- deck nav ---------------- */
const slides=[...document.querySelectorAll(".slide")];
const rail=document.getElementById("rail");
let cur=0;
slides.forEach((s,i)=>{
  const b=document.createElement("button");
  b.className="rdot"+(i===0?" on":"");
  b.setAttribute("aria-label","Aller à la diapo "+(i+1));
  b.onclick=()=>show(i);
  rail.appendChild(b);
});
const dots=[...rail.children];
const counter=document.getElementById("counter");
function pad(n){return String(n).padStart(2,"0")}
function show(i){
  if(i<0||i>=slides.length) return;
  slides[cur].classList.remove("active");
  dots[cur].classList.remove("on");
  cur=i;
  slides[cur].classList.add("active");
  dots[cur].classList.add("on");
  counter.innerHTML="<b>"+pad(cur+1)+"</b> / "+pad(slides.length);
  document.getElementById("prev").disabled=(cur===0);
  document.getElementById("next").disabled=(cur===slides.length-1);
  if(slides[cur].id==="s-hero") runHero();
}
function go(d){show(cur+d)}
document.addEventListener("keydown",e=>{
  if(e.key==="ArrowRight"||e.key==="PageDown"||e.key===" "){e.preventDefault();go(1)}
  else if(e.key==="ArrowLeft"||e.key==="PageUp"){e.preventDefault();go(-1)}
  else if(e.key==="Home"){show(0)}
  else if(e.key==="End"){show(slides.length-1)}
});
// touch
let tx=0;
document.addEventListener("touchstart",e=>tx=e.touches[0].clientX,{passive:true});
document.addEventListener("touchend",e=>{
  const dx=e.changedTouches[0].clientX-tx;
  if(Math.abs(dx)>60) go(dx<0?1:-1);
},{passive:true});

/* ---------------- hero SVG signature ---------------- */
const reduce=window.matchMedia("(prefers-reduced-motion:reduce)").matches;
function buildHero(){
  const svg=document.querySelector("#s-hero svg");
  const fibers=svg.querySelector(".fibers");
  const nerve=svg.querySelector(".nerve");
  // pennate fibers along the aponeurosis
  let f="";
  for(let y=60;y<=470;y+=17){
    const off=(y<260)?1:1; // symmetric
    f+=`<line x1="200" y1="${y}" x2="120" y2="${y+34}" class="fib"/>`;
    f+=`<line x1="200" y1="${y}" x2="280" y2="${y+34}" class="fib"/>`;
  }
  fibers.innerHTML=f;
  // nerve arborization: trunk from left entering at motor point, branching
  nerve.innerHTML=`
    <path class="nbr" d="M40,300 C110,290 150,275 190,262"/>
    <path class="nbr" d="M190,262 C205,250 215,236 214,214"/>
    <path class="nbr" d="M190,262 C210,268 232,270 250,286"/>
    <path class="nbr" d="M190,262 C196,282 190,300 176,318"/>
    <path class="nbr" d="M214,214 C210,200 214,190 206,178"/>
    <path class="nbr" d="M250,286 C264,296 268,308 266,322"/>
  `;
}
function runHero(){
  const svg=document.querySelector("#s-hero svg");
  if(!svg) return;
  const fibs=svg.querySelectorAll(".fib");
  const nbrs=svg.querySelectorAll(".nbr");
  const needle=svg.querySelector(".needle");
  const band=svg.querySelector(".band");
  const mp=svg.querySelector(".mp");
  const mpr=svg.querySelector(".mp-ring");
  if(reduce){
    fibs.forEach(f=>{f.style.strokeDashoffset=0;f.style.opacity=.85});
    nbrs.forEach(n=>{n.style.strokeDashoffset=0});
    needle.style.opacity=1;needle.style.transform="none";band.style.opacity=.14;mp.style.opacity=1;
    return;
  }
  // reset
  fibs.forEach((f)=>{const L=f.getTotalLength();f.style.strokeDasharray=L;f.style.strokeDashoffset=L;f.style.opacity=0;f.style.transition="none"});
  nbrs.forEach(n=>{const L=n.getTotalLength();n.style.strokeDasharray=L;n.style.strokeDashoffset=L;n.style.transition="none"});
  needle.style.transform="translate(60px,-120px)";needle.style.opacity=0;needle.style.transition="none";
  band.style.opacity=0;mp.style.opacity=0;mpr.style.opacity=0;
  // force reflow
  void svg.getBoundingClientRect();
  // animate fibers
  fibs.forEach((f,i)=>{
    f.style.transition="stroke-dashoffset .7s ease "+(i*22)+"ms, opacity .5s ease "+(i*22)+"ms";
    requestAnimationFrame(()=>{f.style.strokeDashoffset=0;f.style.opacity=.85});
  });
  // nerve
  setTimeout(()=>{
    nbrs.forEach((n,i)=>{
      n.style.transition="stroke-dashoffset .8s ease "+(i*120)+"ms";
      requestAnimationFrame(()=>{n.style.strokeDashoffset=0});
    });
  },500);
  // band + needle + motor point
  setTimeout(()=>{band.style.transition="opacity .6s ease";band.style.opacity=.13;},1300);
  setTimeout(()=>{
    needle.style.transition="transform 1s cubic-bezier(.7,0,.3,1), opacity .4s ease";
    needle.style.transform="translate(0,0)";needle.style.opacity=1;
  },1500);
  setTimeout(()=>{
    mp.style.transition="opacity .3s ease";mp.style.opacity=1;
    pulse(mpr);
  },2450);
}
function pulse(ring){
  let t=0;
  function frame(){
    t+=1;
    const p=(t%90)/90;
    ring.setAttribute("r",5+p*26);
    ring.style.opacity=(1-p)*.6;
    requestAnimationFrame(frame);
  }
  frame();
}

buildHero();
applyLang();
show(0);
runHero();
