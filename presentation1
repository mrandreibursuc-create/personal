<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Du muscle au geste — Présentation du projet</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#0E1116;
  --ink-2:#151A21;
  --ink-3:#1C232C;
  --bone:#EFE9DD;
  --bone-dim:#C8C3B8;
  --muted:#8A94A3;
  --line:rgba(239,233,221,.12);
  --line-strong:rgba(239,233,221,.22);
  --carmine:#C63A2E;
  --carmine-br:#E45747;
  --nerve:#E3B23C;
  --echo:#6FB7B0;
  --shadow:0 24px 60px rgba(0,0,0,.45);
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{
  background:var(--ink);
  color:var(--bone);
  font-family:"Inter",system-ui,sans-serif;
  overflow:hidden;
  -webkit-font-smoothing:antialiased;
}
.mono{font-family:"IBM Plex Mono",monospace}

/* ---- deck shell ---- */
#deck{position:fixed;inset:0}
.slide{
  position:absolute;inset:0;
  display:flex;flex-direction:column;justify-content:center;
  padding:clamp(28px,5vw,84px);
  opacity:0;visibility:hidden;
  transform:translateY(14px);
  transition:opacity .5s ease,transform .5s ease,visibility .5s;
  overflow:hidden;
}
.slide.active{opacity:1;visibility:visible;transform:none;z-index:2}
.slide-inner{width:100%;max-width:1180px;margin:0 auto;position:relative;z-index:2}

/* subtle atlas grid ground */
.slide::before{
  content:"";position:absolute;inset:0;z-index:0;
  background:
    radial-gradient(1200px 700px at 82% -10%, rgba(198,58,46,.10), transparent 60%),
    radial-gradient(900px 600px at -8% 108%, rgba(227,178,60,.06), transparent 55%);
  pointer-events:none;
}

/* ---- typography ---- */
.eyebrow{
  font-family:"IBM Plex Mono",monospace;
  font-size:clamp(11px,1.05vw,13px);
  letter-spacing:.28em;text-transform:uppercase;
  color:var(--carmine-br);
  display:flex;align-items:center;gap:14px;margin-bottom:26px;
}
.eyebrow::before{content:"";width:34px;height:1px;background:var(--carmine)}
h1{
  font-family:"Fraunces",serif;font-weight:600;
  font-size:clamp(46px,8.2vw,124px);line-height:.94;
  letter-spacing:-.015em;
}
h2{
  font-family:"Fraunces",serif;font-weight:600;
  font-size:clamp(30px,4.6vw,60px);line-height:1.02;
  letter-spacing:-.01em;margin-bottom:6px;
}
h3{font-family:"Fraunces",serif;font-weight:600;font-size:clamp(19px,1.7vw,23px);line-height:1.15}
.statement{font-size:clamp(38px,6.2vw,86px);line-height:1;letter-spacing:-.015em}
.lede{
  font-size:clamp(16px,1.55vw,21px);line-height:1.5;color:var(--bone-dim);
  max-width:60ch;font-weight:400;
}
p{line-height:1.55}
em{font-style:italic;color:var(--bone)}
.accent{color:var(--carmine-br)}
.gold{color:var(--nerve)}

/* ---- hero ---- */
#s-hero .slide-inner{display:grid;grid-template-columns:1.15fr .85fr;gap:48px;align-items:center}
.hero-authors{margin-top:34px;font-size:clamp(13px,1.15vw,15.5px);color:var(--bone-dim);line-height:1.9}
.hero-authors b{color:var(--bone);font-weight:600}
.hero-foot{margin-top:30px;display:flex;gap:26px;flex-wrap:wrap;color:var(--muted);
  font-family:"IBM Plex Mono",monospace;font-size:12px;letter-spacing:.06em}
.hero-title small{
  display:block;font-family:"IBM Plex Mono",monospace;font-weight:400;
  font-size:clamp(12.5px,1.35vw,16px);letter-spacing:.02em;line-height:1.5;
  color:var(--bone-dim);margin-top:22px;max-width:44ch;text-transform:none;
}
.hero-art{position:relative;height:min(66vh,560px)}

/* ---- generic layout helpers ---- */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:clamp(18px,2.4vw,40px);align-items:start}
.stack>*+*{margin-top:18px}
.section-head{margin-bottom:clamp(22px,3.2vh,42px)}

/* pillars */
.pillars{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-top:8px}
.pillar{
  background:var(--ink-2);border:1px solid var(--line);border-radius:14px;
  padding:22px 18px 20px;position:relative;overflow:hidden;
  transition:transform .3s ease,border-color .3s ease;
}
.pillar:hover{transform:translateY(-4px);border-color:var(--line-strong)}
.pillar .num{font-family:"IBM Plex Mono",monospace;font-size:12px;color:var(--carmine-br);letter-spacing:.1em}
.pillar h3{margin:14px 0 9px;font-size:clamp(15px,1.35vw,18px)}
.pillar p{font-size:clamp(12.5px,1.05vw,14px);color:var(--muted);line-height:1.5}
.pillar .ic{position:absolute;top:18px;right:16px;opacity:.5}

/* chapter anatomy slide */
.gabarit{display:grid;grid-template-columns:.9fr 1.1fr;gap:40px;align-items:center}
.flow{position:relative;padding-left:26px}
.flow-step{position:relative;padding:16px 0}
.flow-step+.flow-step{border-top:1px solid var(--line)}
.flow-step::before{content:"";position:absolute;left:-26px;top:22px;width:9px;height:9px;border-radius:50%;
  background:var(--carmine);box-shadow:0 0 0 4px rgba(198,58,46,.18)}
.flow::after{content:"";position:absolute;left:-22px;top:16px;bottom:16px;width:1px;background:var(--line-strong)}
.flow-step .k{font-family:"IBM Plex Mono",monospace;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--nerve)}
.flow-step h3{margin:6px 0 4px;font-size:17px}
.flow-step p{font-size:13.5px;color:var(--muted);line-height:1.5}
.pearl{
  background:linear-gradient(180deg,var(--ink-2),var(--ink-3));
  border:1px solid var(--line);border-left:3px solid var(--carmine);
  border-radius:12px;padding:26px 28px;
}
.pearl .tag{font-family:"IBM Plex Mono",monospace;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--carmine-br);margin-bottom:14px}
.pearl h3{margin-bottom:12px;font-size:20px}
.pearl p{font-size:14.5px;color:var(--bone-dim);line-height:1.6}
.pearl .stat{font-family:"IBM Plex Mono",monospace;color:var(--nerve);font-weight:500}

/* chapters map */
.intro-row{display:flex;align-items:center;gap:16px;margin:0 0 18px;padding-bottom:16px;border-bottom:1px solid var(--line)}
.intro-row .region-name{margin-bottom:0}
.mapwrap{display:grid;grid-template-columns:1fr 1fr;gap:clamp(20px,3vw,56px);margin-top:6px}
.region-col h3{display:flex;align-items:baseline;gap:12px;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--line-strong)}
.region-col h3 .lbl{font-family:"IBM Plex Mono",monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);font-weight:400}
.region{margin-bottom:16px}
.region-name{font-family:"IBM Plex Mono",monospace;font-size:11.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--nerve);margin-bottom:8px}
.chips{display:flex;flex-wrap:wrap;gap:7px}
.chip{
  display:inline-flex;align-items:center;gap:7px;
  background:var(--ink-2);border:1px solid var(--line);border-radius:8px;
  padding:6px 10px;font-size:12.5px;color:var(--bone-dim);
  transition:all .22s ease;cursor:default;
}
.chip:hover{border-color:var(--carmine);color:var(--bone);background:var(--ink-3);transform:translateY(-2px)}
.chip .cc{font-family:"IBM Plex Mono",monospace;font-size:10.5px;color:var(--carmine-br)}
.chip.syn{border-style:dashed;color:var(--muted)}
.chip.syn .cc{color:var(--nerve)}

/* team + roles */
.team{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:26px}
.person{background:var(--ink-2);border:1px solid var(--line);border-radius:12px;padding:16px 18px}
.person .nm{font-family:"Fraunces",serif;font-weight:600;font-size:16.5px}
.person .rl{font-size:12.5px;color:var(--muted);margin-top:5px;line-height:1.45}
.person .rl .dot{color:var(--carmine-br)}
.roles{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.role{border:1px solid var(--line-strong);border-radius:14px;padding:22px 20px;background:var(--ink-2);position:relative}
.role.author{border-color:rgba(198,58,46,.5);background:linear-gradient(180deg,rgba(198,58,46,.10),var(--ink-2))}
.role .rtag{font-family:"IBM Plex Mono",monospace;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--carmine-br);margin-bottom:6px}
.role h3{font-size:18px;margin-bottom:10px}
.role ul{list-style:none;font-size:13px;color:var(--muted);line-height:1.5}
.role li{padding-left:16px;position:relative;margin-bottom:6px}
.role li::before{content:"—";position:absolute;left:0;color:var(--carmine)}
.role .cover{margin-top:12px;font-size:11.5px;font-family:"IBM Plex Mono",monospace;color:var(--nerve)}

/* order slide */
.cover-preview{
  background:radial-gradient(120% 140% at 50% 0%,var(--ink-3),var(--ink));
  border:1px solid var(--line-strong);border-radius:16px;
  padding:clamp(30px,4vw,54px);text-align:center;box-shadow:var(--shadow);
}
.cover-preview .kicker{font-family:"IBM Plex Mono",monospace;font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:var(--muted);margin-bottom:20px}
.cover-preview .bt{font-family:"Fraunces",serif;font-weight:600;font-size:clamp(30px,4.4vw,54px);line-height:1;letter-spacing:-.01em}
.cover-preview .bt small{display:block;font-family:"IBM Plex Mono",monospace;font-weight:400;font-size:clamp(11px,1.1vw,13.5px);letter-spacing:.02em;color:var(--bone-dim);margin-top:16px;text-transform:none;line-height:1.5}
.cover-preview .authors{margin-top:26px;font-size:clamp(15px,1.5vw,19px);color:var(--bone);font-weight:500}
.cover-preview .sub{margin-top:12px;font-size:13px;color:var(--muted)}
.cover-preview .pre{margin-top:18px;font-family:"IBM Plex Mono",monospace;font-size:12px;letter-spacing:.08em;color:var(--nerve)}
.order-note{font-size:13.5px;color:var(--muted);line-height:1.6}
.order-note b{color:var(--bone-dim)}

/* author scenarios */
.scenario{background:var(--ink-2);border:1px solid var(--line);border-radius:12px;padding:18px 20px;margin-bottom:12px;transition:border-color .3s ease}
.scenario:hover{border-color:var(--line-strong)}
.scenario .sc-name{font-family:"Fraunces",serif;font-weight:600;font-size:clamp(15px,1.4vw,18px);margin-bottom:14px;display:flex;align-items:baseline;gap:10px}
.scenario .sc-name .sc-tag{font-family:"IBM Plex Mono",monospace;font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--carmine-br);font-weight:500}
.scenario .row{display:grid;grid-template-columns:88px 1fr;gap:12px;align-items:baseline;padding:5px 0}
.scenario .rl{font-family:"IBM Plex Mono",monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;padding-top:2px}
.scenario .rl.au{color:var(--carmine-br)}
.scenario .rl.co{color:var(--muted)}
.scenario .nm{font-size:14px;color:var(--bone-dim);line-height:1.4}
.scenario .row.au .nm{color:var(--bone)}
.ord-close{font-family:"Fraunces",serif;font-weight:600;font-size:clamp(18px,2vw,26px);color:var(--bone);margin-top:18px;line-height:1.2}
.ord-close .gold{color:var(--nerve)}
.author-panel{background:var(--ink-2);border:1px solid var(--line);border-radius:14px;padding:24px 26px}
.author-panel .row{display:grid;grid-template-columns:130px 1fr;gap:16px;align-items:baseline;padding:14px 0;border-top:1px solid var(--line)}
.author-panel .row:first-child{border-top:none}
.author-panel .rl{font-family:"IBM Plex Mono",monospace;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--carmine-br)}
.author-panel .nm{font-size:clamp(15px,1.5vw,21px);color:var(--bone);line-height:1.42}
.author-panel .sub{font-size:clamp(13px,1.05vw,15px);color:var(--muted);line-height:1.55}
.author-panel .note{margin-top:18px;padding-top:16px;border-top:1px dashed var(--line-strong);font-size:13px;color:var(--bone-dim);line-height:1.55}

/* preface (surprise) */
#s-preface{text-align:center;align-items:center}
#s-preface .slide-inner{max-width:900px}
.reveal-name{font-family:"Fraunces",serif;font-weight:600;font-size:clamp(40px,7vw,92px);line-height:1;
  background:linear-gradient(180deg,var(--bone),var(--nerve));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;
  margin:24px 0}
.reveal-sub{color:var(--bone-dim);font-size:clamp(15px,1.6vw,20px);line-height:1.5;max-width:52ch;margin:0 auto}

/* timeline */
.timeline{display:grid;grid-template-columns:repeat(5,1fr);gap:0;margin-top:20px;position:relative}
.tl{position:relative;padding:0 14px}
.tl::before{content:"";position:absolute;top:9px;left:0;right:0;height:2px;background:var(--line-strong)}
.tl:first-child::before{left:50%}
.tl:last-child::before{right:50%}
.tl .node{position:relative;width:18px;height:18px;border-radius:50%;background:var(--ink);border:2px solid var(--carmine);margin:0 auto 18px;z-index:2}
.tl.hot .node{background:var(--carmine);box-shadow:0 0 0 5px rgba(198,58,46,.2)}
.tl .mo{font-family:"IBM Plex Mono",monospace;font-size:11.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--nerve);text-align:center;margin-bottom:8px}
.tl .who{font-size:13px;font-weight:600;text-align:center;margin-bottom:6px}
.tl .desc{font-size:11.5px;color:var(--muted);text-align:center;line-height:1.45}

/* editor */
.ed-main{display:grid;grid-template-columns:1.1fr .9fr;gap:44px;align-items:center}
.ed-card{background:var(--ink-2);border:1px solid var(--line);border-radius:16px;padding:30px 32px}
.ed-card .badge{font-family:"IBM Plex Mono",monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--carmine-br);margin-bottom:10px}
.ed-card .name{font-family:"Fraunces",serif;font-weight:600;font-size:30px;margin-bottom:14px}
.ed-card .name small{display:block;font-family:"IBM Plex Mono",monospace;font-weight:400;font-size:12px;letter-spacing:.08em;color:var(--nerve);margin-top:6px;text-transform:uppercase}
.ed-list{list-style:none}
.ed-list li{padding:11px 0;border-top:1px solid var(--line);font-size:14px;color:var(--bone-dim);display:flex;gap:12px}
.ed-list li .n{font-family:"IBM Plex Mono",monospace;color:var(--nerve);font-size:12px;padding-top:2px}
.ed-list li b{color:var(--bone);font-weight:600}
.plan-b{margin-top:16px;font-size:12.5px;color:var(--muted);font-family:"IBM Plex Mono",monospace}

/* next steps */
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:8px}
.step{background:var(--ink-2);border:1px solid var(--line);border-radius:14px;padding:24px 22px}
.step .sn{font-family:"IBM Plex Mono",monospace;font-size:26px;color:var(--carmine);opacity:.6}
.step h3{margin:10px 0 8px;font-size:17px}
.step p{font-size:13px;color:var(--muted);line-height:1.5}

/* ---- chrome: rail, nav, toggle ---- */
#rail{position:fixed;left:22px;top:50%;transform:translateY(-50%);z-index:20;display:flex;flex-direction:column;gap:11px}
.rdot{width:8px;height:8px;border-radius:50%;background:rgba(239,233,221,.2);border:none;cursor:pointer;padding:0;transition:all .3s ease}
.rdot:hover{background:var(--bone-dim)}
.rdot.on{background:var(--carmine);transform:scale(1.35)}
#topbar{position:fixed;top:20px;right:22px;z-index:20;display:flex;align-items:center;gap:16px}
#counter{font-family:"IBM Plex Mono",monospace;font-size:12px;color:var(--muted);letter-spacing:.08em}
#counter b{color:var(--bone)}
.lang{display:flex;border:1px solid var(--line-strong);border-radius:20px;overflow:hidden}
.lang button{background:none;border:none;color:var(--muted);font-family:"IBM Plex Mono",monospace;font-size:11px;
  padding:6px 12px;cursor:pointer;letter-spacing:.08em;transition:all .2s}
.lang button.on{background:var(--carmine);color:#fff}
#nav{position:fixed;bottom:20px;right:22px;z-index:20;display:flex;gap:8px}
.nbtn{width:42px;height:42px;border-radius:50%;border:1px solid var(--line-strong);background:var(--ink-2);
  color:var(--bone);cursor:pointer;font-size:17px;display:grid;place-items:center;transition:all .2s}
.nbtn:hover{border-color:var(--carmine);background:var(--ink-3)}
.nbtn:disabled{opacity:.3;cursor:default}
#hint{position:fixed;bottom:26px;left:22px;z-index:20;font-family:"IBM Plex Mono",monospace;font-size:11px;color:var(--muted);letter-spacing:.05em}
kbd{border:1px solid var(--line-strong);border-radius:4px;padding:1px 6px;font-family:"IBM Plex Mono",monospace;font-size:10px;color:var(--bone-dim)}

@media (max-width:900px){
  #s-hero .slide-inner{grid-template-columns:1fr}
  .hero-art{display:none}
  .pillars{grid-template-columns:1fr 1fr}
  .gabarit,.ed-main,.mapwrap{grid-template-columns:1fr;gap:24px}
  .team,.roles,.steps{grid-template-columns:1fr}
  .timeline{grid-template-columns:1fr 1fr;gap:22px}
  .tl::before{display:none}
  #rail{display:none}
}
@media (prefers-reduced-motion:reduce){
  *{animation:none!important;transition:opacity .2s ease!important}
}

/* keyword anchors — the slide anchors, the speaker narrates */
.anchors{list-style:none;margin-top:6px}
.anchors li{
  display:flex;align-items:baseline;gap:16px;
  padding:clamp(11px,1.5vh,18px) 0;border-top:1px solid var(--line);
  font-family:"Fraunces",serif;font-weight:500;
  font-size:clamp(19px,2.3vw,30px);line-height:1.12;letter-spacing:-.005em;
}
.anchors li:first-child{border-top:none}
.anchors li .m{
  font-family:"IBM Plex Mono",monospace;font-weight:500;
  font-size:clamp(11px,1vw,13px);color:var(--carmine-br);
  letter-spacing:.05em;flex:0 0 auto;position:relative;top:-2px;
}
.anchors.sm li{font-size:clamp(16px,1.7vw,22px);padding:clamp(9px,1.2vh,14px) 0}
.anchors .sub{color:var(--muted);font-family:"IBM Plex Mono",monospace;font-weight:400;
  font-size:clamp(11px,1vw,13px);letter-spacing:.03em}

/* gabarit pearl: align the descriptive/functional labels in a column */
#s-gabarit .pearl .anchors li{align-items:flex-start;gap:18px}
#s-gabarit .pearl .anchors .m{width:clamp(110px,12vw,150px);white-space:normal;line-height:1.35;top:2px;text-transform:uppercase;letter-spacing:.08em}

/* hero SVG colours (CSS vars don't resolve in SVG presentation attributes) */
#s-hero .apo{stroke:var(--bone-dim)}
#s-hero .fib{stroke:var(--carmine)}
#s-hero .band{fill:var(--nerve)}
#s-hero .nbr{stroke:var(--nerve)}
#s-hero .needle line{stroke:var(--bone)}
#s-hero .needle polygon{fill:var(--bone)}
#s-hero .mp{fill:var(--nerve)}
#s-hero .mp-ring{stroke:var(--nerve)}
</style>
</head>
<body>

<div id="deck">

  <!-- 1 · HERO -->
  <section class="slide active" id="s-hero">
    <div class="slide-inner">
      <div>
        <div class="eyebrow" data-t="hero.eyebrow">Projet d'ouvrage · Neuro-orthopédie</div>
        <div class="hero-title">
          <h1 data-t="hero.title">Du muscle<br>au geste</h1>
          <small data-t="hero.sub">Anatomie fonctionnelle du muscle en neuro-orthopédie — échographie et cibles thérapeutiques dans le traitement de la spasticité.</small>
        </div>
        <div class="hero-foot" style="margin-top:34px">
          <span data-t="hero.f1">30 chapitres · brouillon complet</span>
          <span data-t="hero.f2">Présentation du projet</span>
        </div>
      </div>
      <div class="hero-art">
        <svg viewBox="0 0 400 520" width="100%" height="100%" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
          <!-- central aponeurosis / tendon -->
          <line class="apo" x1="200" y1="40" x2="200" y2="480" stroke="var(--bone-dim)" stroke-width="2.5" opacity=".5"/>
          <!-- pennate muscle fibers -->
          <g class="fibers" stroke="var(--carmine)" stroke-width="2" opacity=".85" fill="none"></g>
          <!-- endplate band (motor point zone) mid-third -->
          <rect class="band" x="150" y="230" width="100" height="60" fill="var(--nerve)" opacity="0" rx="4"/>
          <!-- nerve arborization -->
          <g class="nerve" stroke="var(--nerve)" stroke-width="2.2" fill="none" stroke-linecap="round"></g>
          <!-- needle -->
          <g class="needle">
            <line x1="330" y1="90" x2="252" y2="248" stroke="var(--bone)" stroke-width="2.4"/>
            <polygon points="252,248 258,240 262,250" fill="var(--bone)"/>
          </g>
          <!-- motor point pulse -->
